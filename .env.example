# Launchpad PostgreSQL
LAUNCHPAD_DB=launchpad_db
LAUNCHPAD_USER=launchpad_user
LAUNCHPAD_PASSWORD=changeme

# Auth PostgreSQL
AUTH_DB=user_service_db
AUTH_USER=auth_user
AUTH_PASSWORD=changeme

# ConnectHub PostgreSQL
CONNECTHUB_DB=connecthub_db
CONNECTHUB_USER=connecthub_user
CONNECTHUB_PASSWORD=changeme

# JWT Configuration
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7
JWT_ISSUER_URI=http://auth-service:8080

# Service URLs (internal Docker network addresses)
AUTH_SERVICE_URL=http://auth-service:8080
LAUNCHPAD_SERVICE_URL=http://launchpad-service:8080

# pgAdmin (optional, for DB management)
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=changeme

# Frontend build args (baked into static assets at build time)
# For local development, use localhost URLs
# For production, use your public domain URLs
VITE_API_BASE_URL=/api
VITE_AUTH_URL=http://localhost:3000
VITE_CONNECTHUB_URL=http://localhost:5173
VITE_CONNECTHUB_API_URL=http://localhost:8083

# CORS allowed origins for Spring Boot backends
# Comma-separated list - include all origins that will make API requests
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4173,http://localhost:5173
